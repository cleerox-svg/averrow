---
/*
 * Press kit. Media contact, journalist-ready boilerplate, fast
 * facts, and links to the real brand assets served from /brand/*.
 * No fabricated coverage, awards, or "as seen in" logos. Static
 * markup, no islands.
 */
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");

const assets = [
  { name: "Open Graph image", detail: "1200 × 630 · PNG", href: "/brand/averrow-og.png" },
  { name: "Logo — 256px", detail: "PNG, transparent", href: "/brand/averrow-256.png" },
  { name: "Logo — 512px", detail: "PNG, transparent", href: "/brand/averrow-512.png" },
  { name: "Social tile — 400px", detail: "PNG", href: "/brand/averrow-social-400.png" },
  { name: "Social tile — 800px", detail: "PNG", href: "/brand/averrow-social-800.png" },
  { name: "Social tile — 1500px", detail: "PNG", href: "/brand/averrow-social-1500.png" },
  { name: "Favicon", detail: "SVG, scalable", href: "/favicon.svg" },
];
---

<Layout
  title="Press — Averrow"
  description="Averrow press kit — company boilerplate, fast facts, and brand assets for journalists. Media inquiries route directly to our team."
>
  <section class="pr-hero">
    <div class="container">
      <div class="section-label" style="text-align:center;">Press</div>
      <h1>Press Kit</h1>
      <p>
        Boilerplate, fast facts, and brand assets for journalists and
        media covering Averrow. For interviews or additional detail,
        contact us directly &mdash; we don&rsquo;t have a dedicated
        press line yet.
      </p>
    </div>
  </section>

  <section class="pr-section">
    <div class="container">
      <div class="pr-contact-card">
        <div class="pr-contact-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div class="pr-contact-text">
          <div class="pr-contact-title">Media Inquiries</div>
          <p>
            Reach our team through the <a href={`${base}/contact`}>contact form</a>,
            or email <a href="mailto:hello@averrow.com">hello@averrow.com</a>
            directly. We typically respond within one business day.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="pr-section">
    <div class="container">
      <div class="pr-content">
        <div class="section-label">About Averrow</div>
        <h2>Boilerplate</h2>

        <div class="pr-boilerplate">
          <div class="pr-bp-label">Short version</div>
          <p>
            Averrow is an AI-first threat intelligence and brand
            protection platform built by LRX Enterprises Inc. It helps
            organizations detect and shut down phishing domains, social
            media impersonation, and brand abuse before it reaches
            their customers &mdash; using a 42-agent AI mesh and
            continuous monitoring across 45+ threat and intelligence
            feeds, delivered on edge infrastructure.
          </p>
        </div>

        <div class="pr-boilerplate">
          <div class="pr-bp-label">Long version</div>
          <p>
            Enterprise brand protection has historically cost $20,000
            to $150,000+ per year and required a dedicated security
            analyst to operate. Averrow was built to close that gap:
            an outside-in view of the threats already targeting a
            brand &mdash; phishing infrastructure, lookalike domains,
            email spoofing risk, and social impersonation &mdash;
            fused into a single exposure picture by a mesh of AI
            agents that reason about threats instead of just listing
            them. The platform runs on edge compute (Cloudflare
            Workers), which is a meaningful part of how it&rsquo;s
            priced 50&ndash;66% below incumbent platforms. Averrow
            operates globally and is built by LRX Enterprises Inc.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="pr-section" style="text-align:center;">
    <div class="container">
      <div class="section-label" style="text-align:center;">Fast Facts</div>
      <h2 style="font-family:var(--font-display);font-size:clamp(24px,3vw,36px);font-weight:700;margin-bottom:0.5rem;">At a glance</h2>
    </div>
    <div class="pr-facts">
      <div class="pr-fact"><div class="pr-fact-value">LRX Enterprises Inc.</div><div class="pr-fact-label">Company</div></div>
      <div class="pr-fact"><div class="pr-fact-value">AI Threat Intelligence</div><div class="pr-fact-label">Category</div></div>
      <div class="pr-fact"><div class="pr-fact-value">Global</div><div class="pr-fact-label">Coverage</div></div>
      <div class="pr-fact"><div class="pr-fact-value">42 AI agents</div><div class="pr-fact-label">Agent mesh</div></div>
      <div class="pr-fact"><div class="pr-fact-value">45+</div><div class="pr-fact-label">Threat &amp; intelligence feeds</div></div>
      <div class="pr-fact"><div class="pr-fact-value">Free &middot; $1,499 &middot; $3,999 &middot; Custom</div><div class="pr-fact-label">Pricing tiers</div></div>
    </div>
  </section>

  <section class="pr-section">
    <div class="container">
      <div class="section-label" style="text-align:center;">Brand Assets</div>
      <h2 style="text-align:center;font-family:var(--font-display);font-size:clamp(24px,3vw,36px);font-weight:700;margin-bottom:0.5rem;">Logos &amp; images</h2>
      <p class="pr-assets-intro">Please use these files as-is &mdash; don&rsquo;t recolor, distort, or add effects to the logo.</p>
      <div class="pr-assets-grid">
        {assets.map(asset => (
          <a class="pr-asset-card" href={`${base}${asset.href}`} download>
            <div class="pr-asset-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            </div>
            <div class="pr-asset-name">{asset.name}</div>
            <div class="pr-asset-detail">{asset.detail}</div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="pr-cta">
    <div class="container">
      <h2>Working on a story?</h2>
      <p>Reach out and we&rsquo;ll get you what you need &mdash; quotes, additional detail, or a walkthrough of the platform.</p>
      <div class="pr-cta-actions">
        <a href={`${base}/contact`} class="btn btn-primary">Contact Our Team</a>
        <a href={`${base}/about`} class="btn btn-outline">Read the Full Story</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .pr-hero {
    padding: 5rem 0 2.5rem;
    text-align: center;
    background: var(--gradient-hero);
  }
  .pr-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.1;
  }
  .pr-hero p {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .pr-section { padding: 3rem 0; }
  .pr-section:nth-of-type(even) { background: var(--bg-tertiary); }

  .pr-contact-card {
    max-width: 780px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.25rem;
    align-items: flex-start;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-left: 3px solid var(--amber);
    border-radius: var(--radius-md);
    padding: 1.5rem 1.75rem;
  }
  .pr-contact-icon {
    width: 42px;
    height: 42px;
    border-radius: var(--radius-md);
    background: var(--accent-bg);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pr-contact-icon svg { width: 20px; height: 20px; }
  .pr-contact-title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.05rem;
    margin-bottom: 0.4rem;
  }
  .pr-contact-text p { font-size: 0.92rem; color: var(--text-secondary); line-height: 1.65; }
  .pr-contact-text a { color: var(--accent); font-weight: 600; }
  .pr-contact-text a:hover { text-decoration: underline; }

  .pr-content { max-width: 820px; margin: 0 auto; padding: 0 2rem; }
  .pr-content h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 700;
    margin-bottom: 1.5rem;
  }
  .pr-boilerplate { margin-bottom: 1.75rem; }
  .pr-boilerplate:last-child { margin-bottom: 0; }
  .pr-bp-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  .pr-boilerplate p {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 15.5px;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem 1.5rem;
  }

  .pr-facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 1200px;
    margin: 2rem auto 0;
    padding: 0 2rem;
  }
  .pr-fact {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.25rem;
    text-align: center;
    transition: border-color 0.2s;
  }
  .pr-fact:hover { border-color: var(--accent); }
  .pr-fact-value {
    font-family: var(--font-display);
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
    color: var(--text-primary);
  }
  .pr-fact-label { font-size: 0.78rem; color: var(--text-tertiary); }

  .pr-assets-intro {
    text-align: center;
    color: var(--text-secondary);
    max-width: 560px;
    margin: 0 auto 1.5rem;
    font-size: 0.9rem;
  }
  .pr-assets-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  .pr-asset-card {
    display: block;
    text-align: center;
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.5rem 1rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
  }
  .pr-asset-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-glow);
    transform: translateY(-2px);
    text-decoration: none;
  }
  .pr-asset-icon {
    width: 36px;
    height: 36px;
    margin: 0 auto 0.75rem;
    border-radius: var(--radius-sm);
    background: var(--accent-bg);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pr-asset-icon svg { width: 18px; height: 18px; }
  .pr-asset-name {
    font-family: var(--font-display);
    font-size: 0.88rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 0.25rem;
  }
  .pr-asset-detail {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--text-tertiary);
  }

  .pr-cta { padding: 3rem 0; text-align: center; }
  .pr-cta h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .pr-cta p { color: var(--text-secondary); max-width: 520px; margin: 0 auto 2rem; line-height: 1.7; }
  .pr-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  :global([data-theme="light"]) .pr-contact-card,
  :global([data-theme="light"]) .pr-boilerplate p,
  :global([data-theme="light"]) .pr-fact,
  :global([data-theme="light"]) .pr-asset-card {
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: rgba(226,221,213,0.5);
    box-shadow: 0 4px 24px rgba(0,0,0,0.03), inset 0 1px 0 rgba(255,255,255,0.9);
  }

  @media (max-width: 900px) {
    .pr-facts { grid-template-columns: repeat(2, 1fr); }
    .pr-assets-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .pr-contact-card { grid-template-columns: 1fr; text-align: center; }
    .pr-contact-icon { margin: 0 auto; }
    .pr-facts { grid-template-columns: 1fr; }
    .pr-assets-grid { grid-template-columns: 1fr; }
  }
</style>
