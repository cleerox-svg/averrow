---
/*
 * Careers page. Honest, company-level: mission, how the team works,
 * the general kinds of roles we look for. No fabricated job
 * listings, no named employees. Static markup, no islands.
 */
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<Layout
  title="Careers — Averrow"
  description="Careers at Averrow — a small, global team building AI-native brand protection on edge infrastructure. See how we work and how to reach us."
>
  <section class="car-hero">
    <div class="container">
      <div class="section-label" style="text-align:center;">Careers</div>
      <h1>Small team. Outsized mission.</h1>
      <p>
        Enterprise-grade threat intelligence has always been priced for
        enterprises. We&rsquo;re a small, global team closing that gap
        &mdash; and we&rsquo;re looking for people who want to build
        security tooling that actually gets used.
      </p>
    </div>
  </section>

  <section class="car-section">
    <div class="container">
      <div class="car-content">
        <div class="section-label">The Problem</div>
        <h2>Every company gets targeted. Almost none can afford to watch for it.</h2>
        <p>
          Phishing domains, social impersonation, spoofed email &mdash;
          brand-abuse attacks don&rsquo;t check a company&rsquo;s
          headcount before they launch. But the platforms built to
          catch them cost $20,000 to $150,000+ a year and assume a
          dedicated security analyst is running them. Averrow exists to
          make that same outside-in visibility available to every
          company, not just the ones who can afford it.
        </p>
        <p>
          That&rsquo;s the problem we work on: AI agents that reason
          about threats instead of dumping alerts, delivered on edge
          infrastructure that keeps the economics sane. If that sounds
          like an interesting problem, we want to hear from you.
        </p>
      </div>
    </div>
  </section>

  <section class="car-section" style="text-align:center;">
    <div class="container">
      <div class="section-label" style="text-align:center;">How We Build</div>
      <h2 style="font-family:var(--font-display);font-size:clamp(24px,3vw,36px);font-weight:700;margin-bottom:1.25rem;">What shapes how we work</h2>
    </div>
    <div class="car-principles">
      <div class="car-principle">
        <div class="car-principle-num">01</div>
        <h3>Outside-In First</h3>
        <p>We build for the view an attacker has &mdash; instant, zero-setup scanning &mdash; before we build for the view a security team wants.</p>
      </div>
      <div class="car-principle">
        <div class="car-principle-num">02</div>
        <h3>AI-Native, Not Bolted On</h3>
        <p>Agents reason and narrate; they don&rsquo;t just classify. That shapes the engineering problems we work on day to day.</p>
      </div>
      <div class="car-principle">
        <div class="car-principle-num">03</div>
        <h3>Small On Purpose</h3>
        <p>A small, distributed team means less coordination overhead and more ownership. Everyone is close to the product and the customer.</p>
      </div>
    </div>
  </section>

  <section class="car-section">
    <div class="container">
      <div class="section-label" style="text-align:center;">Where We&rsquo;re Growing</div>
      <h2 style="text-align:center;font-family:var(--font-display);font-size:clamp(24px,3vw,36px);font-weight:700;margin-bottom:0.75rem;">The kinds of people we look for</h2>
      <p class="car-roles-intro">
        We don&rsquo;t keep a running list of open requisitions here.
        These are the general areas we grow into as the platform
        grows &mdash; if one of them is your area, reach out.
      </p>
    </div>
    <div class="car-roles-grid">
      <div class="car-role-card">
        <div class="car-role-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
        </div>
        <h4>Engineering</h4>
        <p>Edge compute, distributed data (D1/KV/R2), and the AI agent mesh itself &mdash; systems work with real security consequences.</p>
      </div>
      <div class="car-role-card">
        <div class="car-role-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2L4 6v6c0 5 3.5 9 8 10 4.5-1 8-5 8-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
        </div>
        <h4>Threat Intelligence &amp; Security Research</h4>
        <p>Feed curation, detection logic, and the judgment calls that separate a real threat from noise.</p>
      </div>
      <div class="car-role-card">
        <div class="car-role-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        </div>
        <h4>Go-to-Market</h4>
        <p>Sales, customer success, and marketing for a security product that has to earn trust before it earns a signature.</p>
      </div>
    </div>
  </section>

  <section class="car-cta">
    <div class="container">
      <h2>Interested in joining us?</h2>
      <p>We&rsquo;re a small team, so we don&rsquo;t always have a live posting for every role &mdash; but we still want to hear from good people. Tell us about yourself.</p>
      <div class="car-cta-actions">
        <a href={`${base}/contact`} class="btn btn-primary">Get in Touch</a>
        <a href={`${base}/about`} class="btn btn-outline">Learn About Averrow</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .car-hero {
    padding: 5rem 0 2.5rem;
    text-align: center;
    background: var(--gradient-hero);
  }
  .car-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(36px, 5vw, 64px);
    font-weight: 800;
    margin-bottom: 1rem;
    line-height: 1.1;
  }
  .car-hero p {
    font-size: 18px;
    color: var(--text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .car-section { padding: 3rem 0; }
  .car-section:nth-of-type(even) { background: var(--bg-tertiary); }
  .car-content { max-width: 820px; margin: 0 auto; padding: 0 2rem; }
  .car-content h2 {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 34px);
    font-weight: 700;
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }
  .car-content p {
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 1.25rem;
    font-size: 16px;
  }

  .car-roles-intro {
    max-width: 620px;
    margin: 0 auto 0.5rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .car-principles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }
  .car-principle {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: all 0.3s;
  }
  .car-principle:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-glow);
    transform: translateY(-2px);
  }
  .car-principle-num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }
  .car-principle h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }
  .car-principle p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.65;
  }

  .car-roles-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    max-width: 1200px;
    margin: 2rem auto 0;
    padding: 0 2rem;
  }
  .car-role-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    transition: all 0.3s;
  }
  .car-role-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-glow);
    transform: translateY(-2px);
  }
  .car-role-icon {
    width: 42px;
    height: 42px;
    border-radius: var(--radius-md);
    background: var(--accent-bg);
    color: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .car-role-icon svg { width: 20px; height: 20px; }
  .car-role-card h4 {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
    color: var(--text-primary);
  }
  .car-role-card p { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.65; }

  .car-cta { padding: 3rem 0; text-align: center; }
  .car-cta h2 {
    font-family: var(--font-display);
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 700;
    margin-bottom: 1rem;
  }
  .car-cta p { color: var(--text-secondary); max-width: 560px; margin: 0 auto 2rem; line-height: 1.7; }
  .car-cta-actions { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  :global([data-theme="light"]) .car-principle,
  :global([data-theme="light"]) .car-role-card {
    background: rgba(255,255,255,0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-color: rgba(226,221,213,0.5);
    box-shadow: 0 4px 24px rgba(0,0,0,0.03), inset 0 1px 0 rgba(255,255,255,0.9);
  }

  @media (max-width: 768px) {
    .car-principles,
    .car-roles-grid { grid-template-columns: 1fr; }
  }
</style>
